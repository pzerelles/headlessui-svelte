{
  "name": "@pzerelles/headlessui-svelte",
  "version": "2.1.2-next.70",
  "repository": {
    "url": "https://github.com/pzerelles/headlessui-svelte"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && npm run package",
    "preview": "vite preview",
    "package": "svelte-kit sync && svelte-package && publint",
    "package:watch": "svelte-package --watch",
    "prepublishOnly": "bun run package",
    "test": "bun run test:integration && npm run test:unit",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "test:integration": "playwright test",
    "test:unit": "vitest",
    "release": "bun run package && changeset publish"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "peerDependencies": {
    "svelte": "^5.53.10"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@changesets/types": "^6.1.0",
    "@playwright/test": "^1.58.2",
    "@pzerelles/heroicons-svelte": "^2.2.3",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.53.4",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/eslint": "^9.6.1",
    "@types/node": "^22.19.15",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-svelte": "^2.46.1",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "outdent": "^0.8.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "publint": "^0.3.18",
    "svelte": "^5.53.10",
    "svelte-check": "^4.4.5",
    "tailwindcss": "^4.2.1",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@floating-ui/core": "^1.7.5",
    "@floating-ui/dom": "^1.7.6",
    "@floating-ui/utils": "^0.2.11",
    "esm-env": "^1.2.2",
    "nanoid": "^5.1.6"
  },
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module"
}
